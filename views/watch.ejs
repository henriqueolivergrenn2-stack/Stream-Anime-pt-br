<% title = anime.title + ' - Ep ' + episode.number + ' - ' + config.siteName %>
<% description = 'Assista ' + anime.title + ' Episódio ' + episode.number + ' online em HD' %>

<!-- PLAYER SECTION - DESIGN PROFISSIONAL -->
<div class="player-page">
    
    <!-- Breadcrumbs -->
    <div class="breadcrumbs">
        <a href="/">Início</a>
        <i class="fas fa-chevron-right"></i>
        <a href="/anime/<%= anime.id %>"><%= anime.title %></a>
        <i class="fas fa-chevron-right"></i>
        <span>Ep <%= episode.number %></span>
    </div>

    <!-- Main Content Grid -->
    <div class="content-grid">
        
        <!-- LEFT: Player + Info -->
        <div class="main-content">
            
            <!-- Video Container -->
            <div class="video-box">
                <div class="player-container" id="playerContainer">
                    <% if (videoType === 'youtube') { %>
                    <iframe src="<%= processedVideoUrl %>" frameborder="0" allowfullscreen allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"></iframe>
                    
                    <% } else if (videoType === 'gdrive') { %>
                    <iframe src="<%= processedVideoUrl %>" frameborder="0" allowfullscreen allow="autoplay; encrypted-media"></iframe>
                    
                    <% } else if (videoType === 'blogger') { %>
                    <iframe src="<%= processedVideoUrl || episode.videoUrl %>" frameborder="0" allowfullscreen></iframe>
                    
                    <% } else if (['mp4upload', 'streamsb', 'doodstream', 'filemoon', 'streamtape', 'vk', 'okru'].includes(videoType)) { %>
                    <iframe src="<%= processedVideoUrl %>" frameborder="0" allowfullscreen scrolling="no" allow="autoplay; fullscreen"></iframe>
                    
                    <% } else { %>
                    <!-- HTML5 PLAYER CUSTOMIZADO -->
                    <video id="html5Player" playsinline webkit-playsinline preload="metadata" poster="<%= episode.thumbnail || anime.coverImage %>">
                        <source src="<%= processedVideoUrl || episode.videoUrl %>" type="video/mp4">
                    </video>
                    
                    <!-- Loading -->
                    <div class="player-loader" id="playerLoader">
                        <div class="loader-spin"></div>
                    </div>
                    
                    <!-- Big Play Button -->
                    <div class="big-play-btn" id="bigPlayBtn" onclick="togglePlay()">
                        <i class="fas fa-play"></i>
                    </div>
                    
                    <!-- Controls Overlay -->
                    <div class="player-controls" id="playerControls">
                        <!-- Top: Title -->
                        <div class="controls-top">
                            <span class="now-playing"><%= anime.title %> - Ep <%= episode.number %></span>
                            <button class="ctrl-btn" onclick="toggleFullscreen()">
                                <i class="fas fa-expand"></i>
                            </button>
                        </div>
                        
                        <!-- Center: Play/Pause -->
                        <div class="controls-center" onclick="togglePlay()">
                            <button class="center-play-btn" id="centerPlayBtn">
                                <i class="fas fa-play"></i>
                            </button>
                        </div>
                        
                        <!-- Bottom: Progress + Buttons -->
                        <div class="controls-bottom">
                            <div class="progress-wrapper" id="progressWrapper">
                                <span class="time-current" id="timeCurrent">0:00</span>
                                <div class="progress-bar" id="progressBar" onclick="seekTo(event)">
                                    <div class="progress-loaded" id="progressLoaded"></div>
                                    <div class="progress-played" id="progressPlayed"></div>
                                </div>
                                <span class="time-total" id="timeTotal">0:00</span>
                            </div>
                            
                            <div class="controls-buttons">
                                <div class="left-btns">
                                    <button class="ctrl-btn" onclick="togglePlay()" id="playBtn">
                                        <i class="fas fa-play"></i>
                                    </button>
                                    <button class="ctrl-btn" onclick="seek(-10)">
                                        <i class="fas fa-undo-alt"></i> 10s
                                    </button>
                                    <button class="ctrl-btn" onclick="seek(10)">
                                        <i class="fas fa-redo-alt"></i> 10s
                                    </button>
                                    <button class="ctrl-btn" onclick="toggleMute()" id="muteBtn">
                                        <i class="fas fa-volume-up"></i>
                                    </button>
                                </div>
                                <div class="right-btns">
                                    <button class="ctrl-btn" onclick="toggleSettings()">
                                        <i class="fas fa-cog"></i>
                                    </button>
                                    <button class="ctrl-btn" onclick="toggleFullscreen()">
                                        <i class="fas fa-expand"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
                
                <!-- Player Tabs -->
                <div class="player-tabs">
                    <button class="tab-btn active" onclick="changeServer('default')">
                        <i class="fas fa-play-circle"></i> Principal
                    </button>
                    <% if (episode.servers && episode.servers.length > 0) { %>
                        <% episode.servers.forEach(function(srv, idx) { %>
                        <button class="tab-btn" onclick="changeServer('<%= idx %>')">
                            <%= srv.name %>
                        </button>
                        <% }) %>
                    <% } %>
                </div>
            </div>

            <!-- Episode Info -->
            <div class="episode-info-box">
                <h1 class="ep-title"><%= anime.title %> <span class="ep-number">Episódio <%= episode.number %></span></h1>
                <% if (episode.title) { %>
                <h2 class="ep-subtitle"><%= episode.title %></h2>
                <% } %>
                
                <div class="ep-meta">
                    <span class="meta-item"><i class="fas fa-calendar"></i> <%= anime.year || '2024' %></span>
                    <span class="meta-item"><i class="fas fa-star"></i> <%= anime.rating ? anime.rating.toFixed(1) : 'N/A' %></span>
                    <span class="meta-item"><i class="fas fa-eye"></i> <%= (anime.views || 0).toLocaleString() %> views</span>
                    <span class="meta-item status-badge <%= anime.status %>">
                        <%= anime.status === 'ongoing' ? 'Em Lançamento' : 'Finalizado' %>
                    </span>
                </div>

                <div class="ep-actions">
                    <button class="action-btn primary" onclick="toggleLike()">
                        <i class="far fa-heart"></i> Favoritar
                    </button>
                    <button class="action-btn" onclick="toggleAutoNext()">
                        <i class="fas fa-toggle-on"></i> Auto Próximo
                    </button>
                    <% if (episode.downloadUrl || episode.videoUrl) { %>
                    <a href="<%= episode.downloadUrl || episode.videoUrl %>" class="action-btn download" download>
                        <i class="fas fa-download"></i> Download
                    </a>
                    <% } %>
                    <button class="action-btn" onclick="reportEpisode()">
                        <i class="fas fa-flag"></i> Reportar
                    </button>
                </div>
            </div>

            <!-- Navigation -->
            <div class="ep-navigation">
                <% if (prevEpisode) { %>
                <a href="/watch/<%= prevEpisode[0] %>" class="nav-ep-btn prev">
                    <i class="fas fa-chevron-left"></i>
                    <div class="nav-info">
                        <span class="nav-label">Anterior</span>
                        <span class="nav-ep">EP <%= prevEpisode[1].number %></span>
                    </div>
                </a>
                <% } else { %>
                <div class="nav-ep-btn prev disabled">
                    <i class="fas fa-chevron-left"></i>
                    <span class="nav-label">Início</span>
                </div>
                <% } %>

                <a href="/anime/<%= anime.id %>" class="nav-list-btn">
                    <i class="fas fa-list"></i>
                    <span>Lista</span>
                </a>

                <% if (nextEpisode) { %>
                <a href="/watch/<%= nextEpisode[0] %>" class="nav-ep-btn next">
                    <div class="nav-info">
                        <span class="nav-label">Próximo</span>
                        <span class="nav-ep">EP <%= nextEpisode[1].number %></span>
                    </div>
                    <i class="fas fa-chevron-right"></i>
                </a>
                <% } else { %>
                <div class="nav-ep-btn next disabled">
                    <span class="nav-label">Final</span>
                    <i class="fas fa-chevron-right"></i>
                </div>
                <% } %>
            </div>

            <!-- Synopsis -->
            <% if (anime.synopsis) { %>
            <div class="synopsis-box">
                <h3><i class="fas fa-info-circle"></i> Sinopse</h3>
                <p><%= anime.synopsis %></p>
            </div>
            <% } %>

            <!-- Comments -->
            <% if (config.commentsEnabled) { %>
            <div class="comments-section">
                <h3><i class="fas fa-comments"></i> Comentários</h3>
                
                <% if (user && user.userId) { %>
                <form class="comment-form" onsubmit="postComment(event)">
                    <div class="comment-user">
                        <div class="user-avatar">
                            <i class="fas fa-user"></i>
                        </div>
                        <div class="comment-input-wrap">
                            <textarea placeholder="Escreva um comentário..." required rows="2"></textarea>
                            <button type="submit" class="btn-send">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                    </div>
                </form>
                <% } else { %>
                <div class="login-to-comment">
                    <a href="/login?redirect=/watch/<%= episode.id %>">Faça login para comentar</a>
                </div>
                <% } %>

                <div class="comments-list" id="commentsList">
                    <% if (comments && comments.length > 0) { %>
                        <% comments.forEach(function([id, comment]) { %>
                        <div class="comment-item">
                            <div class="comment-avatar">
                                <% if (comment.userAvatar) { %>
                                <img src="<%= comment.userAvatar %>" alt="">
                                <% } else { %>
                                <i class="fas fa-user"></i>
                                <% } %>
                            </div>
                            <div class="comment-body">
                                <div class="comment-header">
                                    <span class="comment-name"><%= comment.username %></span>
                                    <span class="comment-date"><%= new Date(comment.createdAt).toLocaleDateString('pt-BR') %></span>
                                </div>
                                <p class="comment-text"><%= comment.content %></p>
                                <div class="comment-footer">
                                    <button class="comment-like" onclick="likeComment('<%= id %>')">
                                        <i class="far fa-thumbs-up"></i> <%= comment.likes || 0 %>
                                    </button>
                                    <% if (user && (user.userId === comment.userId || user.isAdmin)) { %>
                                    <button class="comment-delete" onclick="deleteComment('<%= id %>')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                    <% } else { %>
                    <div class="no-comments">
                        <i class="fas fa-comment-slash"></i>
                        <p>Nenhum comentário ainda. Seja o primeiro!</p>
                    </div>
                    <% } %>
                </div>
            </div>
            <% } %>
        </div>

        <!-- RIGHT: Episodes Sidebar -->
        <div class="sidebar-content">
            <div class="episodes-widget">
                <div class="widget-header">
                    <h3><i class="fas fa-list"></i> Episódios</h3>
                    <div class="ep-search">
                        <input type="text" id="epSearch" placeholder="Buscar ep..." onkeyup="searchEpisodes()">
                        <i class="fas fa-search"></i>
                    </div>
                </div>
                
                <div class="episodes-list" id="episodesList">
                    <% if (allEpisodes && allEpisodes.length > 0) { %>
                        <% allEpisodes.forEach(function([id, ep]) { %>
                        <a href="/watch/<%= id %>" class="ep-item <%= id === episode.id ? 'active' : '' %>" data-number="<%= ep.number %>">
                            <div class="ep-thumb">
                                <img src="<%= ep.thumbnail || anime.coverImage || '/images/default.jpg' %>" alt="" loading="lazy">
                                <% if (id === episode.id) { %>
                                <div class="playing-now"><i class="fas fa-play"></i></div>
                                <% } %>
                            </div>
                            <div class="ep-info">
                                <span class="ep-num">EP <%= ep.number %></span>
                                <% if (ep.title) { %>
                                <span class="ep-name"><%= ep.title %></span>
                                <% } %>
                                <% if (ep.duration) { %>
                                <span class="ep-duration"><i class="fas fa-clock"></i> <%= ep.duration %></span>
                                <% } %>
                            </div>
                        </a>
                        <% }) %>
                    <% } else { %>
                    <div class="no-eps">Nenhum episódio disponível</div>
                    <% } %>
                </div>
            </div>

            <!-- Share -->
            <div class="share-widget">
                <h3><i class="fas fa-share-alt"></i> Compartilhar</h3>
                <div class="share-btns">
                    <button class="share-btn fb" onclick="shareOn('facebook')"><i class="fab fa-facebook-f"></i></button>
                    <button class="share-btn tw" onclick="shareOn('twitter')"><i class="fab fa-twitter"></i></button>
                    <button class="share-btn wa" onclick="shareOn('whatsapp')"><i class="fab fa-whatsapp"></i></button>
                    <button class="share-btn tg" onclick="shareOn('telegram')"><i class="fab fa-telegram-plane"></i></button>
                    <button class="share-btn cp" onclick="copyLink()" title="Copiar link"><i class="fas fa-link"></i></button>
                </div>
            </div>

            <!-- Next Episode -->
            <% if (nextEpisode) { %>
            <div class="next-ep-widget">
                <h3><i class="fas fa-step-forward"></i> Próximo Episódio</h3>
                <a href="/watch/<%= nextEpisode[0] %>" class="next-ep-card">
                    <img src="<%= nextEpisode[1].thumbnail || anime.coverImage %>" alt="" loading="lazy">
                    <div class="next-overlay">
                        <i class="fas fa-play"></i>
                    </div>
                    <div class="next-info">
                        <span class="next-label">EP <%= nextEpisode[1].number %></span>
                        <p class="next-title"><%= nextEpisode[1].title || 'Próximo Episódio' %></p>
                    </div>
                </a>
            </div>
            <% } %>
        </div>
    </div>
</div>

<!-- CSS COMPLETO - DESIGN PROFISSIONAL -->
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        -webkit-tap-highlight-color: transparent;
    }

    :root {
        --primary: #ff4757;
        --primary-dark: #e03e4c;
        --bg-dark: #0f0f0f;
        --bg-card: #1a1a1a;
        --bg-hover: #252525;
        --text-main: #ffffff;
        --text-muted: #a0a0a0;
        --border: #2a2a2a;
        --success: #2ed573;
        --warning: #ffa502;
    }

    body {
        background: var(--bg-dark);
        color: var(--text-main);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        line-height: 1.5;
    }

    /* Breadcrumbs */
    .breadcrumbs {
        padding: 12px 16px;
        background: var(--bg-card);
        border-bottom: 1px solid var(--border);
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        overflow-x: auto;
        white-space: nowrap;
    }

    .breadcrumbs a {
        color: var(--primary);
        text-decoration: none;
    }

    .breadcrumbs i {
        font-size: 10px;
    }

    /* Layout Grid */
    .content-grid {
        display: grid;
        grid-template-columns: 1fr;
        max-width: 1400px;
        margin: 0 auto;
    }

    @media (min-width: 1024px) {
        .content-grid {
            grid-template-columns: 1fr 320px;
            gap: 20px;
            padding: 20px;
        }
    }

    /* Video Box */
    .video-box {
        background: #000;
        position: relative;
    }

    @media (min-width: 1024px) {
        .video-box {
            border-radius: 12px;
            overflow: hidden;
        }
    }

    /* Player Container - TAMANHO OTIMIZADO PARA MOBILE */
    .player-container {
        position: relative;
        width: 100%;
        height: 220px;
        background: #000;
    }

    @media (min-width: 480px) {
        .player-container {
            height: 280px;
        }
    }

    @media (min-width: 768px) {
        .player-container {
            height: 400px;
        }
    }

    @media (min-width: 1024px) {
        .player-container {
            height: 480px;
        }
    }

    .player-container iframe,
    .player-container video {
        width: 100%;
        height: 100%;
        border: none;
        display: block;
    }

    /* Loader */
    .player-loader {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.8);
        z-index: 5;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s;
    }

    .player-loader.active {
        opacity: 1;
    }

    .loader-spin {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(255,255,255,0.2);
        border-top-color: var(--primary);
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @keyframes spin {
        to { transform: rotate(360deg); }
    }

    /* Big Play Button */
    .big-play-btn {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 70px;
        height: 70px;
        background: rgba(255,71,87,0.9);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 4;
        transition: all 0.3s;
        box-shadow: 0 4px 20px rgba(255,71,87,0.4);
    }

    .big-play-btn:hover {
        transform: translate(-50%, -50%) scale(1.1);
    }

    .big-play-btn.hidden {
        opacity: 0;
        pointer-events: none;
    }

    .big-play-btn i {
        font-size: 28px;
        color: white;
        margin-left: 4px;
    }

    /* Player Controls Overlay */
    .player-controls {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 40%, rgba(0,0,0,0.3) 100%);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 12px;
        opacity: 0;
        transition: opacity 0.3s;
        z-index: 10;
    }

    .player-controls.active {
        opacity: 1;
    }

    .player-container:hover .player-controls,
    .player-container.paused .player-controls {
        opacity: 1;
    }

    /* Controls Top */
    .controls-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .now-playing {
        font-size: 13px;
        color: rgba(255,255,255,0.9);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 80%;
    }

    /* Controls Center */
    .controls-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        cursor: pointer;
    }

    .center-play-btn {
        width: 60px;
        height: 60px;
        background: rgba(255,255,255,0.95);
        border: none;
        border-radius: 50%;
        color: #000;
        font-size: 24px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s;
    }

    .center-play-btn:active {
        transform: scale(0.95);
    }

    /* Controls Bottom */
    .controls-bottom {
        margin-top: auto;
    }

    .progress-wrapper {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
    }

    .time-current, .time-total {
        font-size: 11px;
        color: rgba(255,255,255,0.9);
        font-family: monospace;
        min-width: 36px;
    }

    .progress-bar {
        flex: 1;
        height: 4px;
        background: rgba(255,255,255,0.3);
        border-radius: 2px;
        position: relative;
        cursor: pointer;
    }

    .progress-loaded {
        position: absolute;
        height: 100%;
        background: rgba(255,255,255,0.2);
        border-radius: 2px;
    }

    .progress-played {
        position: absolute;
        height: 100%;
        background: var(--primary);
        border-radius: 2px;
        width: 0%;
    }

    .controls-buttons {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .left-btns, .right-btns {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .ctrl-btn {
        background: rgba(255,255,255,0.15);
        border: none;
        color: white;
        padding: 8px 12px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 4px;
        transition: all 0.2s;
    }

    .ctrl-btn:hover {
        background: rgba(255,255,255,0.25);
    }

    .ctrl-btn i {
        font-size: 14px;
    }

    /* Player Tabs */
    .player-tabs {
        display: flex;
        gap: 8px;
        padding: 12px;
        background: var(--bg-card);
        border-top: 1px solid var(--border);
        overflow-x: auto;
        scrollbar-width: none;
    }

    .player-tabs::-webkit-scrollbar {
        display: none;
    }

    .tab-btn {
        padding: 8px 16px;
        background: var(--bg-hover);
        border: 1px solid var(--border);
        border-radius: 20px;
        color: var(--text-muted);
        font-size: 13px;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.2s;
    }

    .tab-btn.active {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
    }

    /* Episode Info Box */
    .episode-info-box {
        padding: 16px;
        background: var(--bg-card);
        border-bottom: 1px solid var(--border);
    }

    .ep-title {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .ep-number {
        background: var(--primary);
        color: white;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 13px;
        font-weight: 700;
    }

    .ep-subtitle {
        font-size: 14px;
        color: var(--text-muted);
        margin-bottom: 12px;
    }

    .ep-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 16px;
        font-size: 13px;
        color: var(--text-muted);
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .meta-item i {
        color: var(--primary);
    }

    .status-badge {
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .status-badge.ongoing {
        background: rgba(46, 213, 115, 0.2);
        color: var(--success);
    }

    .status-badge.completed {
        background: rgba(255, 165, 2, 0.2);
        color: var(--warning);
    }

    /* Episode Actions */
    .ep-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .action-btn {
        padding: 10px 16px;
        background: var(--bg-hover);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-main);
        font-size: 13px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        transition: all 0.2s;
    }

    .action-btn:hover {
        background: var(--bg-dark);
    }

    .action-btn.primary {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }

    .action-btn.primary:hover {
        background: var(--primary-dark);
    }

    .action-btn.download {
        background: rgba(46, 213, 115, 0.1);
        border-color: var(--success);
        color: var(--success);
    }

    /* Navigation */
