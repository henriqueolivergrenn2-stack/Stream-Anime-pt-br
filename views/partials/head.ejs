<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title : config.seo?.title || config.siteName %></title>
<meta name="description" content="<%= typeof description !== 'undefined' ? description : config.seo?.description || config.siteDescription %>">
<meta name="keywords" content="<%= config.seo?.keywords || 'anime, online, hd, legendado' %>">

<!-- Favicon -->
<link rel="icon" type="image/png" href="/images/favicon.png">

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!-- Custom CSS -->
<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/admin.css">

<!-- Open Graph -->
<meta property="og:title" content="<%= typeof title !== 'undefined' ? title : config.siteName %>">
<meta property="og:description" content="<%= typeof description !== 'undefined' ? description : config.siteDescription %>">
<meta property="og:type" content="website">
<meta property="og:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : '/images/og-image.jpg' %>">
