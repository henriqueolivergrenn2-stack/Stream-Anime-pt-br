<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#0f0f1a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>Relatórios - <%= config.siteName %></title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        /* ============================================
           ANDROID MOBILE-FIRST DESIGN
           ============================================ */
        :root {
            /* Cores Otimizadas para OLED */
            --primary: #ff4757;
            --primary-light: #ff6b81;
            --secondary: #2f3542;
            --accent: #5352ed;

            /* Fundos - Preto puro para economizar bateria OLED */
            --bg-dark: #000000;
            --bg-card: #0f0f1a;
            --bg-hover: #1a1a2e;
            --bg-input: #16213e;

            /* Texto - Alto contraste para sol */
            --text-primary: #ffffff;
            --text-secondary: #b0b0b0;
            --text-muted: #6c757d;

            /* Status */
            --success: #00d26a;
            --warning: #ffb800;
            --danger: #ff4757;
            --info: #00d2d3;

            /* Touch targets - mínimo 48px para Android */
            --touch-min: 48px;
            --touch-comfortable: 56px;

            /* Espaçamento mobile */
            --space-xs: 0.5rem;
            --space-sm: 0.75rem;
            --space-md: 1rem;
            --space-lg: 1.5rem;

            /* Bordas arredondadas mobile */
            --radius-sm: 8px;
            --radius-md: 12px;
            --radius-lg: 16px;
            --radius-xl: 24px;

            /* Sombras para dark mode */
            --shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
            --shadow-lg: 0 4px 20px rgba(0, 0, 0, 0.7);

            /* Transições suaves */
            --transition: all 0.2s ease;
            --bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }

        /* ============================================
           RESET E BASE MOBILE
           ============================================ */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
            -webkit-touch-callout: none;
        }

        html {
            font-size: 16px;
            scroll-behavior: smooth;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: var(--bg-dark);
            color: var(--text-primary);
            line-height: 1.5;
            min-height: 100vh;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* ============================================
           HEADER MOBILE FIXO
           ============================================ */
        .app-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: var(--touch-comfortable);
            background: var(--bg-card);
            border-bottom: 1px solid var(--secondary);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 var(--space-md);
            z-index: 1000;
            backdrop-filter: blur(10px);
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: var(--space-sm);
        }

        .menu-btn {
            width: var(--touch-min);
            height: var(--touch-min);
            display: flex;
            align-items: center;
            justify-content: center;
            background: none;
            border: none;
            color: var(--text-primary);
            font-size: 1.25rem;
            border-radius: var(--radius-sm);
            transition: var(--transition);
        }

        .menu-btn:active {
            background: var(--bg-hover);
            transform: scale(0.95);
        }

        .header-title {
            font-size: 1.1rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .header-title i {
            color: var(--primary);
        }

        .header-actions {
            display: flex;
            gap: var(--space-xs);
        }

        .icon-btn {
            width: var(--touch-min);
            height: var(--touch-min);
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-hover);
            border: none;
            color: var(--text-primary);
            font-size: 1.1rem;
            border-radius: var(--radius-sm);
            transition: var(--transition);
            position: relative;
        }

        .icon-btn:active {
            transform: scale(0.9);
            background: var(--secondary);
        }

        .badge {
            position: absolute;
            top: 2px;
            right: 2px;
            background: var(--primary);
            color: white;
            font-size: 0.65rem;
            padding: 2px 5px;
            border-radius: 10px;
            font-weight: 700;
            min-width: 18px;
            text-align: center;
        }

        /* ============================================
           CONTEÚDO PRINCIPAL
           ============================================ */
        .main-content {
            padding-top: calc(var(--touch-comfortable) + var(--space-md));
            padding-bottom: calc(var(--touch-comfortable) + var(--space-lg));
            min-height: 100vh;
        }

        .container {
            padding: 0 var(--space-md);
        }

        /* ============================================
           STATS CARDS - HORIZONTAL SCROLL
           ============================================ */
        .stats-scroll {
            display: flex;
            gap: var(--space-sm);
            overflow-x: auto;
            padding: var(--space-md);
            margin: 0 calc(-1 * var(--space-md));
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }

        .stats-scroll::-webkit-scrollbar {
            display: none;
        }

        .stat-card {
            flex: 0 0 auto;
            width: 140px;
            background: var(--bg-card);
            border-radius: var(--radius-md);
            padding: var(--space-md);
            border: 1px solid var(--secondary);
            scroll-snap-align: start;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--primary);
        }

        .stat-card.warning::before { background: var(--warning); }
        .stat-card.success::before { background: var(--success); }
        .stat-card.info::before { background: var(--info); }

        .stat-icon {
            width: 36px;
            height: 36px;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            margin-bottom: var(--space-sm);
            background: rgba(255, 71, 87, 0.15);
            color: var(--primary);
        }

        .stat-card.warning .stat-icon { background: rgba(255, 184, 0, 0.15); color: var(--warning); }
        .stat-card.success .stat-icon { background: rgba(0, 210, 106, 0.15); color: var(--success); }
        .stat-card.info .stat-icon { background: rgba(0, 210, 211, 0.15); color: var(--info); }

        .stat-value {
            font-size: 1.75rem;
            font-weight: 700;
            margin-bottom: 2px;
        }

        .stat-label {
            font-size: 0.75rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ============================================
           FILTROS COLLAPSIBLE
           ============================================ */
        .filters-section {
            background: var(--bg-card);
            border-radius: var(--radius-md);
            margin: var(--space-md) 0;
            border: 1px solid var(--secondary);
            overflow: hidden;
        }

        .filters-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: var(--space-md);
            cursor: pointer;
            user-select: none;
        }

        .filters-header:active {
            background: var(--bg-hover);
        }

        .filters-title {
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .filters-toggle {
            transition: transform 0.3s ease;
        }

        .filters-toggle.open {
            transform: rotate(180deg);
        }

        .filters-body {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }

        .filters-body.open {
            max-height: 500px;
        }

        .filters-content {
            padding: 0 var(--space-md) var(--space-md);
            display: flex;
            flex-direction: column;
            gap: var(--space-md);
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: var(--space-xs);
        }

        .form-label {
            font-size: 0.8rem;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .form-input,
        .form-select {
            height: var(--touch-comfortable);
            background: var(--bg-input);
            border: 1px solid var(--secondary);
            color: var(--text-primary);
            padding: 0 var(--space-md);
            border-radius: var(--radius-sm);
            font-size: 1rem;
            transition: var(--transition);
            appearance: none;
        }

        .form-input:focus,
        .form-select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px rgba(255, 71, 87, 0.2);
        }

        .select-wrapper {
            position: relative;
        }

        .select-wrapper::after {
            content: '107';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            right: var(--space-md);
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-secondary);
            pointer-events: none;
        }

        .search-box {
            position: relative;
        }

        .search-box i {
            position: absolute;
            left: var(--space-md);
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
        }

        .search-box .form-input {
            padding-left: 2.5rem;
        }

        .btn {
            height: var(--touch-comfortable);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0 var(--space-lg);
            border: none;
            border-radius: var(--radius-sm);
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }

        .btn:active {
            transform: scale(0.98);
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-primary:active {
            background: var(--primary-light);
        }

        .btn-block {
            width: 100%;
        }

        /* ============================================
           LISTA DE RELATÓRIOS - CARDS
           ============================================ */
        .reports-list {
            display: flex;
            flex-direction: column;
            gap: var(--space-md);
            padding-bottom: var(--space-lg);
        }

        .report-card {
            background: var(--bg-card);
            border-radius: var(--radius-md);
            border: 1px solid var(--secondary);
            overflow: hidden;
            transition: var(--transition);
        }

        .report-card:active {
            transform: scale(0.99);
            border-color: var(--primary);
        }

        .report-card.resolved {
            opacity: 0.7;
            border-color: var(--success);
        }

        .report-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: var(--space-md);
            border-bottom: 1px solid var(--secondary);
        }

        .report-id {
            font-family: 'Courier New', monospace;
            font-size: 0.75rem;
            color: var(--text-muted);
            background: var(--bg-hover);
            padding: 4px 8px;
            border-radius: 4px;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
        }

        .status-badge.pending {
            background: rgba(255, 184, 0, 0.15);
            color: var(--warning);
        }

        .status-badge.resolved {
            background: rgba(0, 210, 106, 0.15);
            color: var(--success);
        }

        .report-body {
            padding: var(--space-md);
        }

        .report-anime {
            display: flex;
            align-items: center;
            gap: var(--space-sm);
            margin-bottom: var(--space-md);
        }

        .anime-thumb {
            width: var(--touch-min);
            height: var(--touch-min);
            border-radius: var(--radius-sm);
            background: var(--bg-hover);
            object-fit: cover;
            flex-shrink: 0;
        }

        .anime-info h4 {
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 2px;
            line-height: 1.3;
        }

        .anime-info span {
            font-size: 0.8rem;
            color: var(--text-secondary);
        }

        .report-reason {
            background: var(--bg-hover);
            padding: var(--space-md);
            border-radius: var(--radius-sm);
            font-size: 0.9rem;
            line-height: 1.5;
            color: var(--text-secondary);
            margin-bottom: var(--space-md);
            border-left: 3px solid var(--primary);
        }

        .report-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        .reporter {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .reporter-avatar {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            font-weight: 700;
        }

        .report-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-sm);
            padding: var(--space-md);
            border-top: 1px solid var(--secondary);
        }

        .btn-action {
            height: var(--touch-comfortable);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            border: none;
            border-radius: var(--radius-sm);
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }

        .btn-action:active {
            transform: scale(0.95);
        }

        .btn-view {
            background: var(--bg-hover);
            color: var(--text-primary);
            border: 1px solid var(--secondary);
        }

        .btn-resolve {
            background: var(--success);
            color: white;
        }

        .btn-resolve:active {
            background: #00b85c;
        }

        .btn-resolved {
            background: transparent;
            color: var(--success);
            border: 1px solid var(--success);
            grid-column: 1 / -1;
        }

        /* ============================================
           EMPTY STATE
           ============================================ */
        .empty-state {
            text-align: center;
            padding: var(--space-lg) var(--space-md);
        }

        .empty-icon {
            width: 100px;
            height: 100px;
            background: var(--bg-card);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto var(--space-md);
            font-size: 2.5rem;
            color: var(--primary);
            border: 2px solid var(--secondary);
        }

        .empty-title {
            font-size: 1.25rem;
            margin-bottom: var(--space-xs);
        }

        .empty-text {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        /* ============================================
           BOTTOM NAVIGATION
           ============================================ */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: calc(var(--touch-comfortable) + env(safe-area-inset-bottom));
            padding-bottom: env(safe-area-inset-bottom);
            background: var(--bg-card);
            border-top: 1px solid var(--secondary);
            display: flex;
            justify-content: space-around;
            align-items: center;
            z-index: 1000;
            backdrop-filter: blur(10px);
        }

        .nav-item {
            flex: 1;
            height: var(--touch-comfortable);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 4px;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.65rem;
            transition: var(--transition);
            position: relative;
        }

        .nav-item.active {
            color: var(--primary);
        }

        .nav-item i {
            font-size: 1.25rem;
        }

        .nav-badge {
            position: absolute;
            top: 4px;
            right: calc(50% - 20px);
            background: var(--primary);
            color: white;
            font-size: 0.6rem;
            padding: 2px 5px;
            border-radius: 10px;
            font-weight: 700;
            min-width: 16px;
            text-align: center;
        }

        /* ============================================
           MODAL BOTTOM SHEET
           ============================================ */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(5px);
            display: none;
            z-index: 2000;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .modal-overlay.active {
            display: flex;
            opacity: 1;
        }

        .modal-sheet {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--bg-card);
            border-radius: var(--radius-xl) var(--radius-xl) 0 0;
            max-height: 85vh;
            overflow-y: auto;
            transform: translateY(100%);
            transition: transform 0.3s var(--bounce);
            z-index: 2001;
        }

        .modal-overlay.active .modal-sheet {
            transform: translateY(0);
        }

        .modal-handle {
            width: 40px;
            height: 4px;
            background: var(--secondary);
            border-radius: 2px;
            margin: var(--space-sm) auto;
        }

        .modal-header {
            padding: var(--space-md) var(--space-lg);
            border-bottom: 1px solid var(--secondary);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-title {
            font-size: 1.1rem;
            font-weight: 700;
        }

        .modal-close {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: none;
            background: var(--bg-hover);
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
        }

        .modal-body {
            padding: var(--space-lg);
        }

        .detail-group {
            margin-bottom: var(--space-lg);
        }

        .detail-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: var(--space-xs);
        }

        .detail-value {
            background: var(--bg-hover);
            padding: var(--space-md);
            border-radius: var(--radius-sm);
            font-size: 0.95rem;
            word-break: break-word;
        }

        .detail-value.reason {
            border-left: 3px solid var(--primary);
            line-height: 1.6;
        }

        .modal-footer {
            padding: var(--space-md) var(--space-lg) calc(var(--space-lg) + env(safe-area-inset-bottom));
            border-top: 1px solid var(--secondary);
            display: flex;
            gap: var(--space-md);
        }

        .modal-footer .btn {
            flex: 1;
        }

        /* ============================================
           TOAST (SNACKBAR)
           ============================================ */
        .toast-container {
            position: fixed;
            bottom: calc(var(--touch-comfortable) + var(--space-lg) + env(safe-area-inset-bottom));
            left: var(--space-md);
            right: var(--space-md);
            z-index: 3000;
            display: flex;
            flex-direction: column;
            gap: var(--space-sm);
        }

        .toast {
            background: var(--bg-card);
            border: 1px solid var(--secondary);
            border-radius: var(--radius-sm);
            padding: var(--space-md);
            display: flex;
            align-items: center;
            gap: var(--space-sm);
            box-shadow: var(--shadow-lg);
            animation: slideUp 0.3s ease;
            font-size: 0.9rem;
        }

        .toast.success { border-left: 4px solid var(--success); }
        .toast.error { border-left: 4px solid var(--danger); }
        .toast.info { border-left: 4px solid var(--info); }

        @keyframes slideUp {
            from { transform: translateY(100%); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        @keyframes slideDown {
            from { transform: translateY(0); opacity: 1; }
            to { transform: translateY(100%); opacity: 0; }
        }

        .toast.hiding {
            animation: slideDown 0.3s ease forwards;
        }

        /* ============================================
           PULL TO REFRESH INDICATOR
           ============================================ */
        .ptr-indicator {
            position: fixed;
            top: var(--touch-comfortable);
            left: 50%;
            transform: translateX(-50%) translateY(-100%);
            background: var(--bg-card);
            padding: var(--space-sm) var(--space-md);
            border-radius: 0 0 var(--radius-md) var(--radius-md);
            border: 1px solid var(--secondary);
            border-top: none;
            display: flex;
            align-items: center;
            gap: var(--space-sm);
            font-size: 0.85rem;
            color: var(--text-secondary);
            transition: transform 0.3s ease;
            z-index: 999;
        }

        .ptr-indicator.visible {
            transform: translateX(-50%) translateY(0);
        }

        .ptr-indicator i {
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* ============================================
           SKELETON LOADING
           ============================================ */
        .skeleton {
            background: linear-gradient(90deg, var(--bg-hover) 25%, var(--bg-input) 50%, var(--bg-hover) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
            border-radius: var(--radius-sm);
        }

        @keyframes shimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* ============================================
           UTILITÁRIOS
           ============================================ */
        .hidden {
            display: none !important;
        }

        .text-success { color: var(--success); }
        .text-warning { color: var(--warning); }
        .text-danger { color: var(--danger); }
        .text-muted { color: var(--text-muted); }

        /* ============================================
           ANIMAÇÕES
           ============================================ */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .report-card {
            animation: fadeIn 0.3s ease forwards;
        }

        /* Stagger animation para cards */
        .report-card:nth-child(1) { animation-delay: 0.05s; }
        .report-card:nth-child(2) { animation-delay: 0.1s; }
        .report-card:nth-child(3) { animation-delay: 0.15s; }
        .report-card:nth-child(4) { animation-delay: 0.2s; }
        .report-card:nth-child(5) { animation-delay: 0.25s; }
    </style>
</head>
<body>
    <!-- PULL TO REFRESH INDICATOR -->
    <div class="ptr-indicator" id="ptrIndicator">
        <i class="fas fa-sync-alt"></i>
        <span>Atualizando...</span>
    </div>

    <!-- HEADER -->
    <header class="app-header">
        <div class="header-left">
            <a href="/admin" class="menu-btn">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h1 class="header-title">
                <i class="fas fa-exclamation-triangle"></i>
                Relatórios
            </h1>
        </div>
        <div class="header-actions">
            <button class="icon-btn" onclick="toggleFilters()" id="filterBtn">
                <i class="fas fa-filter"></i>
            </button>
            <button class="icon-btn" onclick="refreshData()">
                <i class="fas fa-sync-alt"></i>
            </button>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <main class="main-content">
        <div class="container">
            <% 
                const reportsList = Object.entries(reports);
                const pendingReports = reportsList.filter(([_, r]) => !r.resolved);
                const resolvedReports = reportsList.filter(([_, r]) => r.resolved);
            %>

            <!-- STATS SCROLL -->
            <div class="stats-scroll">
                <div class="stat-card warning">
                    <div class="stat-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <div class="stat-value"><%= pendingReports.length %></div>
                    <div class="stat-label">Pendentes</div>
                </div>
                <div class="stat-card success">
                    <div class="stat-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="stat-value"><%= resolvedReports.length %></div>
                    <div class="stat-label">Resolvidos</div>
                </div>
                <div class="stat-card info">
                    <div class="stat-icon">
                        <i class="fas fa-list"></i>
                    </div>
                    <div class="stat-value"><%= reportsList.length %></div>
                    <div class="stat-label">Total</div>
                </div>
                <div class="stat-card" style="--primary: #ff4757;">
                    <div class="stat-icon" style="background: rgba(255, 71, 87, 0.15); color: #ff4757;">
                        <i class="fas fa-percentage"></i>
                    </div>
                    <div class="stat-value">
                        <%= reportsList.length > 0 ? Math.round((resolvedReports.length / reportsList.length) * 100) : 0 %>%
                    </div>
                    <div class="stat-label">Resolução</div>
                </div>
            </div>

            <!-- FILTERS -->
            <div class="filters-section" id="filtersSection">
                <div class="filters-header" onclick="toggleFilters()">
                    <span class="filters-title">
                        <i class="fas fa-filter"></i>
                        Filtros
                    </span>
                    <i class="fas fa-chevron-down filters-toggle" id="filtersToggle"></i>
                </div>
                <div class="filters-body" id="filtersBody">
                    <div class="filters-content">
                        <div class="form-group search-box">
                            <label class="form-label">Buscar</label>
                            <i class="fas fa-search"></i>
                            <input type="text" class="form-input" id="searchInput" placeholder="Anime, usuário...">
                        </div>

                        <div class="form-group">
                            <label class="form-label">Status</label>
                            <div class="select-wrapper">
                                <select class="form-select" id="statusFilter">
                                    <option value="all">Todos</option>
                                    <option value="pending" selected>Pendentes</option>
                                    <option value="resolved">Resolvidos</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Ordenar</label>
                            <div class="select-wrapper">
                                <select class="form-select" id="sortFilter">
                                    <option value="newest">Mais recentes</option>
                                    <option value="oldest">Mais antigos</option>
                                </select>
                            </div>
                        </div>

                        <button class="btn btn-primary btn-block" onclick="applyFilters()">
                            <i class="fas fa-check"></i>
                            Aplicar Filtros
                        </button>
                    </div>
                </div>
            </div>

            <!-- REPORTS LIST -->
            <div class="reports-list" id="reportsList">
                <% if (reportsList.length === 0) { %>
                    <div class="empty-state">
                        <div class="empty-icon">
                            <i class="fas fa-inbox"></i>
                        </div>
                        <h3 class="empty-title">Nenhum relatório</h3>
                        <p class="empty-text">Não há relatórios de links quebrados no momento.</p>
                    </div>
                <% } else { %>
                    <% 
                        const sortedReports = reportsList.sort((a, b) => 
                            new Date(b[1].createdAt) - new Date(a[1].createdAt)
                        );
                    %>
                    <% sortedReports.forEach(([id, report]) => { %>
                        <div class="report-card <%= report.resolved ? 'resolved' : '' %>" 
                             data-id="<%= id %>" 
                             data-resolved="<%= report.resolved %>"
                             data-anime="<%= report.animeId %>"
                             data-user="<%= report.username %>"
                             data-reason="<%= report.reason %>">

                            <div class="report-header">
                                <span class="report-id">#<%= id.substring(0, 8) %></span>
                                <% if (report.resolved) { %>
                                    <span class="status-badge resolved">
                                        <i class="fas fa-check"></i>
                                        Resolvido
                                    </span>
                                <% } else { %>
                                    <span class="status-badge pending">
                                        <i class="fas fa-circle"></i>
                                        Pendente
                                    </span>
                                <% } %>
                            </div>

                            <div class="report-body">
                                <div class="report-anime">
                                    <img src="/images/default-anime.jpg" alt="" class="anime-thumb">
                                    <div class="anime-info">
                                        <h4><%= report.animeId ? report.animeId.substring(0, 25) : 'Anime não encontrado' %></h4>
                                        <% if (report.episodeId) { %>
                                            <span>EP <%= report.episodeId.substring(0, 8) %></span>
                                        <% } %>
                                    </div>
                                </div>

                                <div class="report-reason">
                                    <%= report.reason && report.reason.length > 100 ? report.reason.substring(0, 100) + '...' : (report.reason || 'Sem motivo especificado') %>
                                </div>

                                <div class="report-meta">
                                    <div class="reporter">
                                        <div class="reporter-avatar">
                                            <%= (report.username || 'A').charAt(0).toUpperCase() %>
                                        </div>
                                        <span><%= report.username || 'Anônimo' %></span>
                                    </div>
                                    <span>
                                        <%= new Date(report.createdAt).toLocaleDateString('pt-BR') %>
                                    </span>
                                </div>
                            </div>

                            <div class="report-actions">
                                <button class="btn-action btn-view" onclick="viewDetails('<%= id %>')">
                                    <i class="fas fa-eye"></i>
                                    Ver
                                </button>
                                <% if (!report.resolved) { %>
                                    <form action="/admin/report/resolve/<%= id %>" method="POST" style="display: contents;">
                                        <button type="submit" class="btn-action btn-resolve">
                                            <i class="fas fa-check"></i>
                                            Resolver
                                        </button>
                                    </form>
                                <% } else { %>
                                    <button class="btn-action btn-resolved" disabled>
                                        <i class="fas fa-check-double"></i>
                                        Resolvido
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </main>

    <!-- BOTTOM NAVIGATION -->
    <nav class="bottom-nav">
        <a href="/admin" class="nav-item">
            <i class="fas fa-chart-line"></i>
            <span>Dashboard</span>
        </a>
        <a href="/admin/animes" class="nav-item">
            <i class="fas fa-film"></i>
            <span>Animes</span>
        </a>
        <a href="/admin/users" class="nav-item">
            <i class="fas fa-users"></i>
            <span>Usuários</span>
        </a>
        <a href="/admin/reports" class="nav-item active">
            <i class="fas fa-exclamation-triangle"></i>
            <span>Relatórios</span>
            <% if (pendingReports.length > 0) { %>
                <span class="nav-badge"><%= pendingReports.length > 99 ? '99+' : pendingReports.length %></span>
            <% } %>
        </a>
    </nav>

    <!-- MODAL BOTTOM SHEET -->
    <div class="modal-overlay" id="modalOverlay" onclick="closeModal(event)">
        <div class="modal-sheet" onclick="event.stopPropagation()">
            <div class="modal-handle"></div>
            <div class="modal-header">
                <h3 class="modal-title">Detalhes do Relatório</h3>
                <button class="modal-close" onclick="closeModal()">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body" id="modalBody">
                <!-- Preenchido via JS -->
            </div>
            <div class="modal-footer" id="modalFooter">
                <button class="btn btn-secondary" onclick="closeModal()">Fechar</button>
                <button class="btn btn-success" id="resolveBtn" onclick="resolveCurrent()">
                    <i class="fas fa-check"></i>
                    Resolver
                </button>
            </div>
        </div>
    </div>

    <!-- TOAST CONTAINER -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        // Dados dos relatórios
        const reportsData = <%- JSON.stringify(reports) %>;
        let currentReportId = null;
        let startY = 0;
        let isPulling = false;

        // ============================================
        // PULL TO REFRESH
        // ============================================
        document.addEventListener('touchstart', (e) => {
            if (window.scrollY === 0) {
                startY = e.touches[0].clientY;
                isPulling = true;
            }
        }, { passive: true });

        document.addEventListener('touchmove', (e) => {
            if (!isPulling) return;

            const currentY = e.touches[0].clientY;
            const diff = currentY - startY;

            if (diff > 80 && window.scrollY === 0) {
                document.getElementById('ptrIndicator').classList.add('visible');
            }
        }, { passive: true });

        document.addEventListener('touchend', () => {
            if (document.getElementById('ptrIndicator').classList.contains('visible')) {
                setTimeout(() => {
                    window.location.reload();
                }, 500);
            }
            isPulling = false;
        });

        // ============================================
        // FILTROS
        // ============================================
        function toggleFilters() {
            const body = document.getElementById('filtersBody');
            const toggle = document.getElementById('filtersToggle');
            body.classList.toggle('open');
            toggle.classList.toggle('open');
        }

        function applyFilters() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const statusFilter = document.getElementById('statusFilter').value;
            const cards = document.querySelectorAll('.report-card');
            let visibleCount = 0;

            cards.forEach(card => {
                const id = card.getAttribute('data-id');
                const report = reportsData[id];
                const isResolved = card.getAttribute('data-resolved') === 'true';

                let statusMatch = true;
                if (statusFilter === 'pending' && isResolved) statusMatch = false;
                if (statusFilter === 'resolved' && !isResolved) statusMatch = false;

                let searchMatch = true;
                if (searchTerm) {
                    const searchContent = (
                        (report.animeId || '') + ' ' +
                        (report.username || '') + ' ' +
                        (report.reason || '')
                    ).toLowerCase();
                    searchMatch = searchContent.includes(searchTerm);
                }

                if (statusMatch && searchMatch) {
                    card.style.display = '';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            // Fechar filtros após aplicar
            toggleFilters();

            showToast(visibleCount + ' relatórios encontrados', 'success');
        }

        // Busca em tempo real
        let searchTimeout;
        document.getElementById('searchInput').addEventListener('input', () => {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(applyFilters, 300);
        });

        // ============================================
        // MODAL
        // ============================================
        function viewDetails(reportId) {
            currentReportId = reportId;
            const report = reportsData[reportId];

            if (!report) return;

            const modalBody = document.getElementById('modalBody');
            const resolveBtn = document.getElementById('resolveBtn');

            if (report.resolved) {
                resolveBtn.style.display = 'none';
            } else {
                resolveBtn.style.display = 'flex';
            }

            modalBody.innerHTML = `
                <div class="detail-group">
                    <div class="detail-label">ID do Relatório</div>
                    <div class="detail-value" style="font-family: monospace; font-size: 0.85rem;">
                        ${reportId}
                    </div>
                </div>

                <div class="detail-group">
                    <div class="detail-label">Anime</div>
                    <div class="detail-value">
                        ${report.animeId || 'N/A'}
                    </div>
                </div>

                ${report.episodeId ? `
                <div class="detail-group">
                    <div class="detail-label">Episódio</div>
                    <div class="detail-value" style="font-family: monospace;">
                        ${report.episodeId}
                    </div>
                </div>
                ` : ''}

                <div class="detail-group">
                    <div class="detail-label">Reportado por</div>
                    <div class="detail-value">
                        <div class="reporter" style="display: flex; align-items: center; gap: 0.5rem;">
                            <div class="reporter-avatar" style="width: 30px; height: 30px; font-size: 0.8rem;">
                                ${(report.username || 'A').charAt(0).toUpperCase()}
                            </div>
                            <span>${report.username || 'Anônimo'}</span>
                        </div>
                    </div>
                </div>

                <div class="detail-group">
                    <div class="detail-label">Data</div>
                    <div class="detail-value">
                        ${new Date(report.createdAt).toLocaleString('pt-BR')}
                    </div>
                </div>

                <div class="detail-group">
                    <div class="detail-label">Motivo</div>
                    <div class="detail-value reason">
                        ${report.reason || 'Nenhum motivo especificado'}
                    </div>
                </div>

                ${report.resolved ? `
                <div class="detail-group">
                    <div class="detail-label">Resolvido</div>
                    <div class="detail-value" style="color: var(--success);">
                        <i class="fas fa-check-circle"></i>
                        ${report.resolvedAt ? new Date(report.resolvedAt).toLocaleString('pt-BR') : 'Data não registrada'}
                        ${report.resolvedBy ? `<br><small>por ${report.resolvedBy}</small>` : ''}
                    </div>
                </div>
                ` : ''}
            `;

            document.getElementById('modalOverlay').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(event) {
            if (event && event.target !== document.getElementById('modalOverlay') && event.target !== event.currentTarget) {
                return;
            }
            document.getElementById('modalOverlay').classList.remove('active');
            document.body.style.overflow = '';
            currentReportId = null;
        }

        function resolveCurrent() {
            if (currentReportId) {
                showToast('Resolvendo relatório...', 'info');
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = `/admin/report/resolve/${currentReportId}`;
                document.body.appendChild(form);
                form.submit();
            }
        }

        // Swipe down to close modal
        let modalStartY = 0;
        const modalSheet = document.querySelector('.modal-sheet');

        modalSheet.addEventListener('touchstart', (e) => {
            modalStartY = e.touches[0].clientY;
        }, { passive: true });

        modalSheet.addEventListener('touchmove', (e) => {
            const currentY = e.touches[0].clientY;
            const diff = currentY - modalStartY;

            if (diff > 50 && modalSheet.scrollTop === 0) {
                modalSheet.style.transform = `translateY(${diff}px)`;
            }
        }, { passive: true });

        modalSheet.addEventListener('touchend', (e) => {
            const currentY = e.changedTouches[0].clientY;
            const diff = currentY - modalStartY;

            if (diff > 100) {
                closeModal();
            }
            modalSheet.style.transform = '';
        });

        // ============================================
        // TOAST
        // ============================================
        function showToast(message, type = 'success') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;

            const icon = type === 'success' ? 'check-circle' : 
                        type === 'error' ? 'exclamation-circle' : 'info-circle';

            toast.innerHTML = `
                <i class="fas fa-${icon}"></i>
                <span>${message}</span>
            `;

            container.appendChild(toast);

            // Haptic feedback se disponível
            if (navigator.vibrate) {
                navigator.vibrate(50);
            }

            setTimeout(() => {
                toast.classList.add('hiding');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // ============================================
        // UTILITÁRIOS
        // ============================================
        function refreshData() {
            showToast('Atualizando...', 'info');
            setTimeout(() => {
                window.location.reload();
            }, 500);
        }

        // Botão voltar do Android
        document.addEventListener('backbutton', (e) => {
            if (document.getElementById('modalOverlay').classList.contains('active')) {
                e.preventDefault();
                closeModal();
            }
        });

        // Verificar URL params
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('success')) {
            showToast('Operação realizada com sucesso!', 'success');
        }
        if (urlParams.has('error')) {
            showToast('Erro ao realizar operação', 'error');
        }

        // Haptic feedback nos botões
        document.querySelectorAll('button, .nav-item').forEach(btn => {
            btn.addEventListener('click', () => {
                if (navigator.vibrate) {
                    navigator.vibrate(30);
                }
            });
        });
    </script>
</body>
</html>