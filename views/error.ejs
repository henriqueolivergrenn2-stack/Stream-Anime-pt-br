<% title = 'Erro - ' + (config && config.siteName ? config.siteName : 'AnimeStream') %>

<section class="auth-section">
    <div class="auth-container" style="grid-template-columns: 1fr; max-width: 500px;">
        <div class="auth-card" style="text-align: center;">
            <div class="auth-logo" style="background: var(--danger);">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            
            <h1 style="margin-bottom: 15px;"><%= typeof message !== 'undefined' ? message : 'Ops! Algo deu errado' %></h1>
            
            <% if (typeof error !== 'undefined' && error) { %>
            <p style="color: var(--text-muted); margin-bottom: 30px;"><%= error %></p>
            <% } %>
            
            <a href="/" class="btn btn-primary btn-block">
                <i class="fas fa-home"></i>
                <span>Voltar ao Início</span>
            </a>
        </div>
    </div>
</section>
