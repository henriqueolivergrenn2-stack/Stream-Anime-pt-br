<% title = 'Watchlist - ' + config.siteName %>

<section class="watchlist-page">
    <div class="container">
        <div class="page-header-with-actions">
            <h1>
                <i class="fas fa-bookmark"></i>
                <span>Minha Watchlist</span>
            </h1>
        </div>
        
        <% if (watchlist && watchlist.length > 0) { %>
        <div class="content-grid grid-6">
            <% watchlist.forEach(anime => { %>
            <div class="anime-card">
                <a href="/anime/<%= anime.id %>" class="card-link">
                    <div class="card-image">
                        <img src="<%= anime.coverImage || '/images/default-anime.jpg' %>" alt="<%= anime.title %>" loading="lazy">
                        <div class="card-overlay">
                            <div class="play-btn">
                                <i class="fas fa-play"></i>
                            </div>
                        </div>
                        <% if (anime.rating) { %>
                        <div class="rating-badge">
                            <i class="fas fa-star"></i>
                            <%= anime.rating.toFixed(1) %>
                        </div>
                        <% } %>
                        <% if (anime.isAdult) { %>
                        <div class="adult-badge-small">+18</div>
                        <% } %>
                    </div>
                    <div class="card-info">
                        <h3 class="card-title"><%= anime.title %></h3>
                        <p class="card-meta">
                            <% if (anime.year) { %>
                            <span><i class="fas fa-calendar"></i> <%= anime.year %></span>
                            <% } %>
                            <% if (anime.status) { %>
                            <span class="status <%= anime.status %>">
                                <%= anime.status === 'ongoing' ? 'Em Lançamento' : anime.status === 'completed' ? 'Completo' : 'Pausado' %>
                            </span>
                            <% } %>
                        </p>
                    </div>
                </a>
            </div>
            <% }) %>
        </div>
        <% } else { %>
        <div class="empty-state">
            <i class="fas fa-bookmark"></i>
            <h2>Watchlist vazia</h2>
            <p>Você ainda não adicionou nenhum anime à sua watchlist.</p>
            <a href="/" class="btn btn-primary" style="margin-top: 20px;">
                <i class="fas fa-home"></i>
                <span>Explorar Animes</span>
            </a>
        </div>
        <% } %>
    </div>
</section>
